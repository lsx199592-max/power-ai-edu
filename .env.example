# ==========================================
# 电力AI在线教育平台 - 环境变量配置示例
# 复制此文件为 .env.local 或在 Vercel Dashboard 中配置
# ==========================================

# --- Supabase 配置 ---
# Supabase 项目 URL（必填）
# 从 Supabase 项目设置 -> API 中获取
REACT_APP_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Public Key（必填）
# 从 Supabase 项目设置 -> API 中获取
# 注意：此为公开 anon key，前端可安全使用
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# --- MEOO 内部配置（可选，用于 iframe 等特殊场景） ---
# 如果使用 window.MEOO_CONFIG 运行时注入，可忽略以下变量
# REACT_APP_MEOO_URL=https://your-meoo-endpoint.com
